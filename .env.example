# Copy to .env and fill in. .env is gitignored.

# Database. Schema provider is PostgreSQL (see prisma/schema.prisma).
# Local dev (docker-compose.yml):
DATABASE_URL="postgresql://portal:portal@localhost:5433/jectarone?schema=public"
# Production (Neon/Supabase):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Session signing secret. Generate a strong one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-secret"

# Public base URL — used for links in verification / password-reset emails.
APP_URL="http://localhost:3000"   # production: https://portal.jectar.one

# Transactional email (authenticated SMTP). REQUIRED in production for email
# verification + password reset. If unset in dev, emails are written to
# .mail-outbox/ instead of being sent.
# SMTP_HOST="mail.jectar.one"
# SMTP_PORT="465"           # 465=SSL, 587=STARTTLS
# SMTP_SECURE="true"        # true for 465
# SMTP_USER="no-reply@jectar.one"
# SMTP_PASS="..."
# EMAIL_FROM="JectarOne <no-reply@jectar.one>"

# Error monitoring (optional but recommended). If unset, Sentry is a no-op.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Evidence file storage (S3 / Cloudflare R2). Local dev uses MinIO
# (docker-compose.yml). If unset, uploads fall back to metadata-only mode.
# S3_BUCKET="jectarone-evidence"
# S3_REGION="us-east-1"           # R2: "auto"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_ENDPOINT="http://localhost:9000"   # R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# The bucket must be PRIVATE and allow browser PUT from the app origin (CORS):
# [{ "AllowedOrigins": ["https://portal.jectar.one"], "AllowedMethods": ["PUT","GET"],
#    "AllowedHeaders": ["*"], "ExposeHeaders": ["ETag"], "MaxAgeSeconds": 3000 }]
#
# AI security assistant (optional). Provider is selected by AI_PROVIDER, or
# auto-detected from whichever key is set. Unset / "mock" = deterministic offline
# provider (no network) so the feature degrades gracefully. AI runs server-side
# only — the browser never talks to the provider, so no CSP change is needed.
# AI_PROVIDER="anthropic"          # "anthropic" | "openai" | "mock"
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-8"   # default
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"          # default
