# Copy to .env and fill in. .env is gitignored.

# Local dev uses SQLite (zero setup):
DATABASE_URL="file:./dev.db"

# Production (Postgres, e.g. Neon) — swap provider in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Session signing secret. Generate a strong one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="replace-with-a-long-random-secret"

# Evidence file storage (S3 or S3-compatible). OPTIONAL — if unset, the app
# falls back to evidence-metadata-only mode (no real uploads).
# S3_BUCKET="jectarone-evidence"
# S3_REGION="eu-central-1"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_ENDPOINT=""   # leave empty for AWS S3; set for R2/MinIO/Spaces (forces path-style)
#
# The bucket must allow browser PUT uploads from the app origin. Example CORS:
# [{ "AllowedOrigins": ["https://portal.jectar.one"],
#    "AllowedMethods": ["PUT","GET"],
#    "AllowedHeaders": ["*"],
#    "ExposeHeaders": ["ETag"], "MaxAgeSeconds": 3000 }]
# Keep the bucket PRIVATE (no public access) — files are served only via
# short-lived presigned URLs.
