// JectarOne Client Portal — data model.
// Dev: SQLite. Production: PostgreSQL (Neon). Set DATABASE_URL.
// No DB-native enums (kept portable + evolvable); enum-like fields are validated in app code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  emailVerifiedAt DateTime?   // null until the user confirms their email
  emailPrefs     String       @default("{}") // JSON of per-category email opt-ins
  createdAt      DateTime     @default(now())
  memberships    Membership[]
  tokens         Token[]
  sessions       Session[]
  apiTokens      ApiToken[]
  assessments  Assessment[] @relation("AssessmentCreatedBy")
  findings         Finding[]        @relation("FindingCreatedBy")
  evidence         Evidence[]       @relation("EvidenceUploadedBy")
  activities       ActivityLog[]    @relation("ActivityUser")
  assets           Asset[]          @relation("AssetCreatedBy")
  reports          Report[]         @relation("ReportGeneratedBy")
  assignedFindings Finding[]        @relation("FindingAssignee")
  acceptedFindings Finding[]        @relation("FindingAcceptedBy")
  comments         FindingComment[] @relation("CommentAuthor")
  revisions        FindingRevision[] @relation("RevisionUser")
  retestsRequested Retest[]         @relation("RetestRequestedBy")
  retestsAssigned  Retest[]         @relation("RetestAssignedTo")
}

model Organization {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  createdAt   DateTime      @default(now())
  memberships Membership[]
  assessments Assessment[]
  findings    Finding[]
  evidence    Evidence[]
  activities  ActivityLog[]
  assets      Asset[]
  reports     Report[]
  comments    FindingComment[]
  apiTokens   ApiToken[]
  findingTemplates FindingTemplate[]
  engagements Engagement[]
  retests     Retest[]
}

// Reusable finding library — consultants create findings from templates with
// CVSS/CWE/OWASP/MITRE defaults and remediation boilerplate pre-filled.
// organizationId is set for org-private templates; null = built-in (seeded).
model FindingTemplate {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  category       String        // e.g. "Web", "Network", "Cloud", "AD", "API", "Mobile"
  severity       String        @default("Medium")
  likelihood     String        @default("Medium")
  impact         String        @default("Medium")
  cvssScore      Float?
  cvssVector     String?
  cwe            String?
  owaspCategory  String?
  mitreTechnique String?
  description    String?
  businessImpact String?
  remediation    String?
  references     String?
  createdById    String?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, category])
  @@index([organizationId, archivedAt])
}

// Tracked login sessions — enables the device/active-sessions list and remote
// revocation. The JWT carries this row's id as `sid`; getSession rejects a token
// whose session row is missing or revoked.
model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

// Organization API tokens for the REST API (Authorization: Bearer). Only the
// SHA-256 hash is stored; a short prefix is kept for display.
model ApiToken {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  tokenHash      String       @unique
  prefix         String       // e.g. "jo_ab12" for display
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  revokedAt      DateTime?

  @@index([organizationId])
}

// Brute-force / credential-stuffing throttle for login (and signup).
// Serverless-safe: shared state in the DB (per-email + per-IP counts in a
// sliding window). Rows are pruned per-email on successful login; stale rows
// are ignored by the windowed count query. Run `prisma migrate deploy`
// (or `prisma db push`) after deploying this model.
model LoginAttempt {
  id        String   @id @default(cuid())
  key       String   // lowercased email the attempt targeted
  ip        String   @default("0.0.0.0")
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([ip, createdAt])
}

// Single-use, hashed, expiring tokens for email verification + password reset.
// The raw token is emailed; only its SHA-256 hash is stored.
model Token {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "verify" | "reset"
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}

model Membership {
  id             String       @id @default(cuid())
  role           String       @default("MEMBER") // OWNER | ADMIN | MEMBER
  createdAt      DateTime     @default(now())
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// Sprint 8 — Engagement: top-level container grouping assessments across the
// scoping → delivery → remediation → retest → close lifecycle.
model Engagement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  clientName     String
  status         String       @default("Scoping") // Scoping|Active|Reporting|Remediation|Retest|Closed
  scope          String?
  startDate      DateTime?
  endDate        DateTime?
  leadConsultant String?
  createdById    String?
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assessments    Assessment[]

  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
}

// Sprint 2 — Assessments.
model Assessment {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Optional link to a parent Engagement (additive — legacy assessments have none).
  engagementId     String?
  engagement       Engagement?  @relation(fields: [engagementId], references: [id], onDelete: SetNull)

  clientName       String
  type             String       // Web | Network | Cloud | ActiveDirectory | ISO27001 | NISTCSF | Other
  scope            String?
  status           String       @default("Draft") // Draft | InProgress | Review | Delivered
  startDate        DateTime?
  endDate          DateTime?
  leadConsultant   String?
  executiveSummary String?
  notes            String?

  createdById      String?
  createdBy        User?        @relation("AssessmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  archivedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  findings         Finding[]
  activities       ActivityLog[]
  reports          Report[]
  reportConfig     ReportConfig?

  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
}

// Sprint 3 — Findings.
model Finding {
  id               String     @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessmentId     String
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  title            String
  description      String?
  technicalDetails String?
  businessImpact   String?
  remediation      String?
  verificationSteps String?

  severity         String     @default("Medium")   // Critical | High | Medium | Low | Informational
  likelihood       String     @default("Medium")   // VeryLow | Low | Medium | High | VeryHigh
  impact           String     @default("Medium")   // VeryLow | Low | Medium | High | VeryHigh
  cvssScore        Float?     // 0.0 - 10.0
  cvssVector       String?

  cwe              String?    // e.g. CWE-79
  owaspCategory    String?    // e.g. A03 Injection
  mitreTechnique   String?    // e.g. T1190
  affectedAsset    String?
  affectedAssetType String?   // Domain | URL | IP | Server | ActiveDirectory | Azure | AWS | API | MobileApp
  assetId          String?    // optional link to a formal Asset record (Sprint 4); affectedAsset text stays for quick/free-text entry
  asset            Asset?     @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Sprint 5 workflow: Open | InProgress | ReadyForValidation | Resolved | AcceptedRisk | FalsePositive
  // (legacy Sprint 3 values Fixed/Verified are still accepted and treated as closed for backward compatibility)
  status           String     @default("Open")

  // Sprint 7 review/publication lifecycle (separate from remediation `status`):
  // Draft | InReview | Approved | Published | Reopened. CLIENT role only sees Published.
  reviewState      String     @default("Draft")

  createdById      String?
  createdBy        User?      @relation("FindingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Sprint 5 — assignment
  assigneeId       String?
  assignee         User?      @relation("FindingAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assignedById     String?
  assignedAt       DateTime?

  // Sprint 5 — SLA
  dueDate          DateTime?
  slaOverridden    Boolean    @default(false)

  // Sprint 5 — risk acceptance
  acceptedRiskReason String?
  acceptedRiskById   String?
  acceptedRiskBy     User?    @relation("FindingAcceptedBy", fields: [acceptedRiskById], references: [id], onDelete: SetNull)
  acceptedRiskAt     DateTime?
  acceptedRiskUntil  DateTime?

  // Sprint 5 — lifecycle timestamps
  resolvedAt       DateTime?
  validatedAt      DateTime?

  archivedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  evidence         Evidence[]
  activities       ActivityLog[]
  comments         FindingComment[]
  revisions        FindingRevision[]
  retests          Retest[]

  @@index([organizationId, assessmentId])
  @@index([organizationId, severity])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, assigneeId])
  @@index([organizationId, dueDate])
  @@index([cvssScore])
  @@index([assetId])
}

// Sprint 7 — per-assessment report builder configuration (section order/enable,
// custom recommendations, appendix). One row per assessment.
model ReportConfig {
  id             String     @id @default(cuid())
  organizationId String
  assessmentId   String     @unique
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  config         String     @default("{}") // JSON: { order, disabled, customRecommendations, appendix }
  updatedById    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([organizationId])
}

// Sprint 7 — per-edit field-level change history for findings.
// `changes` is a JSON array of { field, from, to } captured on each edit.
model FindingRevision {
  id             String   @id @default(cuid())
  organizationId String
  findingId      String
  finding        Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation("RevisionUser", fields: [userId], references: [id], onDelete: SetNull)
  changes        String   // JSON: [{ field, from, to }]
  createdAt      DateTime @default(now())

  @@index([findingId, createdAt])
}

// Sprint 8 — Retest: the remediation-verification lifecycle for a finding.
// Requested → Scheduled → InProgress → Verified | Failed. A failed retest
// reopens the finding; a verified retest marks it resolved.
model Retest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findingId      String
  finding        Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)

  status         String       @default("Requested")
  requestedById  String?
  requestedBy    User?        @relation("RetestRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?        @relation("RetestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  dueDate        DateTime?
  scheduledFor   DateTime?
  completedAt    DateTime?
  result         String?      // outcome summary recorded at Verified/Failed
  consultantNotes String?
  clientNotes    String?

  evidence       Evidence[]   // new evidence captured during this retest
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([findingId, createdAt])
}

// Sprint 3 — Evidence (metadata; binary storage is a future integration that
// needs no schema change — add a storageKey/url later without migration churn).
model Evidence {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findingId      String
  finding        Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)

  filename       String
  mimeType       String       // screenshot/pdf/txt/json/pcap/zip etc.
  sizeBytes      Int?
  storageKey     String?      // reserved for future cloud storage; null for now
  note           String?

  uploadedById   String?
  uploadedBy     User?        @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  // Sprint 8 — optional link to the retest this evidence was captured during
  // ("new" evidence). Null = original finding evidence ("old").
  retestId       String?
  retest         Retest?      @relation(fields: [retestId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?    // Sprint 5 — soft delete

  @@index([organizationId])
  @@index([findingId])
  @@index([retestId])
}

// Sprint 5 — collaboration comments on a finding (soft-delete, editable, Markdown body).
model FindingComment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findingId      String
  finding        Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)

  body           String       // Markdown; @mentions parsed at render
  visibility     String       @default("internal") // "internal" (team only) | "client" (client-visible)
  authorId       String?
  author         User?        @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  editedAt       DateTime?
  deletedAt      DateTime?    // soft delete
  createdAt      DateTime     @default(now())

  @@index([findingId, createdAt])
  @@index([organizationId])
}

// Sprint 3 — Activity log (audit trail). Survives finding/assessment deletion (SetNull).
model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  action         String       // e.g. finding.created, finding.archived, finding.deleted
  detail         String?

  assessmentId   String?
  assessment     Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  findingId      String?
  finding        Finding?     @relation(fields: [findingId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?        @relation("ActivityUser", fields: [userId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([assessmentId])
}

// Sprint 4 — Asset inventory. Findings may optionally link to a formal Asset
// (assetId); the free-text affectedAsset/affectedAssetType on Finding still
// works standalone for quick entry, so this is purely additive.
model Asset {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name           String
  type           String       // Domain | URL | IP | Server | ActiveDirectory | Azure | AWS | API | MobileApp | Other
  identifier     String?      // hostname / IP / URL / ARN, etc.
  notes          String?

  createdById    String?
  createdBy      User?        @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  findings       Finding[]

  @@index([organizationId, type])
  @@index([organizationId, archivedAt])
}

// Sprint 4 — Report generation log. The PDF itself is generated on demand
// (live) from current Assessment + Finding data rather than stored as a
// blob (no object storage yet); this row is the audit record of each export.
model Report {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessmentId   String
  assessment     Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  title          String
  findingCount   Int          @default(0) // snapshot count at generation time
  format         String       @default("PDF")

  generatedById  String?
  generatedBy    User?        @relation("ReportGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, assessmentId])
  @@index([organizationId, createdAt])
}
