{
  "name": "jectarone-portal",
  "version": "0.1.0",
  "private": true,
  "description": "JectarOne Client Portal — clients access their assessments, findings, and reports.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:studio": "prisma studio",
    "test": "node --test test/unit.test.mjs test/security.test.mjs",
    "test:unit": "node --test test/unit.test.mjs test/security.test.mjs",
    "test:storage": "node --test test/integration/storage.test.mjs",
    "test:billing": "node --test test/integration/billing-metering.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@prisma/client": "^6.2.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.65.0",
    "bcryptjs": "^2.4.3",
    "docx": "^9.7.1",
    "jose": "^5.9.6",
    "next": "^15.1.4",
    "nodemailer": "^9.0.3",
    "openai": "^6.46.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
